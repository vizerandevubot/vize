# Bu dosyayi Render'a YUKLEMEYIN. Sadece hangi Environment Variable'lari
# Render dashboard'una (Environment sekmesi) tek tek eklemeniz gerektigini
# gosterir. Degerleri KURULUM.md'deki adimlarla elde edersiniz.

# --- Zorunlu (Telegram + veritabani) ---
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_SECRET=kendi-belirleyeceginiz-tahmin-edilemez-bir-metin
MONGO_URI=mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- E-posta ile hatirlatici bildirimi (opsiyonel, EmailJS) ---
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxx
# Birden fazla Gmail'e ayni anda gitsin isterseniz virgulle ayirin:
USER_EMAIL=sevinckudret1@gmail.com,ikincigmailin@gmail.com

# --- Google Takvim (opsiyonel) ---
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

# --- Gelen kutusu izleme: Gmail, Yandex, Yahoo, iCloud, Zoho, GMX, Mail.ru ---
# ve IMAP destekleyen HERHANGI baska bir saglayici (Outlook/Hotmail HARIC -
# bu bot tarafindan desteklenmiyor, Microsoft OAuth zorunlu kildigi icin
# kaldirildi). Sunucu adresi, e-posta adresinin @'dan sonraki kismina
# bakilarak OTOMATIK bulunur - siz sadece adres ve uygulama sifresini
# giriyorsunuz. Her hesap icin numarayi bir artirarak devam edin
# (IMAP_ADDRESS_1, IMAP_ADDRESS_2, ... 30'a kadar).
IMAP_ADDRESS_1=hesap1@gmail.com
IMAP_APP_PASSWORD_1=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_2=hesap2@gmail.com
IMAP_APP_PASSWORD_2=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_3=hesap3@yandex.com
IMAP_APP_PASSWORD_3=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_4=hesap4@yandex.com
IMAP_APP_PASSWORD_4=xxxxxxxxxxxxxxxx

# Bilinmeyen/ozel bir domain (sirket maili gibi) kullanan bir hesabiniz
# varsa, sunucu adresini elle belirtmeniz gerekir:
# IMAP_HOST_5=mail.ozelsirketiniz.com
# IMAP_ADDRESS_5=isim@ozelsirketiniz.com
# IMAP_APP_PASSWORD_5=xxxxxxxxxxxxxxxx

# Bildirimde gorunecek ismi degistirmek isterseniz (opsiyonel):
# IMAP_LABEL_1=Fransa Vize Gmail

# Eklerin (resim/pdf/word) Telegram'a gonderilecek azami boyutu (MB):
MAIL_ATTACHMENT_MAX_MB=20

# --- Mail bildirim ayarlari (opsiyonel) ---
# Bos birakilirsa TUM gelen mailler Telegram'a dusurulur. Doldurulursa
# (virgulle ayrilmis) sadece bu kelimelerden birini iceren mailler dusurulur.
EMAIL_KEYWORDS=vize,visa,vfsglobal,vfs global,appointment,randevu,consulate,embassy,sefaret,konsolosluk,appointment letter,group urn
# OTP kodlari kisa surede gecersiz oldugu icin varsayilan dusuk tutuldu (15sn).
# Hesap sayisi arttikca (30'a yakin) her tarama biraz daha uzun surer; IMAP
# sunucusu "too many connections" derse bu degeri 30-45 saniyeye cikarin.
# Render'in UCRETSIZ plani sadece 0.15 CPU / 512MB RAM verdigi icin (Render
# Metrics sayfasindan dogrulandi), bu kisitli kaynakta cok sik/agir arka plan
# taramasi "Instance failed" ile surecin tekrar tekrar cokup yeniden
# baslatilmasina yol acabiliyor. Kesinti yasiyorsaniz bu degeri 45'e,
# PASSPORT_CHECK_INTERVAL_SECONDS'i 300'e, REMINDER_CHECK_INTERVAL_SECONDS'i
# 30'a cikarmayi deneyin - hiz biraz duser ama kararlilik artar.
MAIL_CHECK_INTERVAL_SECONDS=15
# Ayni anda kac IMAP hesabinin paralel taranacagi. 0.15 CPU'da paralellik
# fayda etmiyor, aksine ani yuk artisina yol aciyor - dusuk tutun (1-2).
IMAP_MAX_WORKERS=2

# --- SMS (opsiyonel, kalici ucretsiz servis yok - bos birakilirsa SMS gonderilmez) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- Hatirlatici kontrol sikligi (opsiyonel, saniye) ---
REMINDER_CHECK_INTERVAL_SECONDS=20

# Sheets'e (bot uzerinden ya da elle) yeni bir pasaport satiri eklenip
# eklenmedigini kontrol etme sikligi (opsiyonel, saniye):
PASSPORT_CHECK_INTERVAL_SECONDS=60

# Gunluk ozet bildiriminin gonderilecegi saat/dakika (Turkiye saati,
# varsayilan 09:00). Ozette: bugunku randevu sayisi, bekleyen kayit sayisi
# ve suresi yakinda dolacak pasaportlar gonderilir.
DAILY_DIGEST_HOUR=9
DAILY_DIGEST_MINUTE=0
# Pasaport suresi bitimine kac gun kala "yakinda dolacak" uyarisi verilsin:
PASSPORT_EXPIRY_WARN_DAYS=180

# --- Ekip erisimi (opsiyonel) ---
# Bos birakilirsa bot tek kisilik calisir (eskisi gibi). Bir deger girerseniz,
# botu Telegram'da acan HERKESIN bu kodu yazmasi gerekir - girdikten sonra
# ayni paylasili hatirlatici/pasaport verisini gorur, ekler, duzenler ve tum
# bildirimleri (hatirlatici, yeni mail, randevu) alir.
TEAM_ACCESS_CODE=

# --- Pasaport -> Google Sheets entegrasyonu ---
# Kurulum adimlari icin GOOGLE_SHEETS_KURULUM.md dosyasina bakin.
# Servis hesabi JSON dosyasinin TUM icerigi (tek satir olarak yapistirin):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Google Sheets linkindeki /d/ ile /edit arasindaki ID:
SHEETS_SPREADSHEET_ID=1h1IwYTLb_5TuoFmpWqnThJsB2_EiaYJYULv_cHek0jo
# Randevu alinan kayitlarin otomatik kopyalandigi master sayfa / hesap listesi sayfasi
# (varsayilanlar tablonuzdaki mevcut isimlerle eslesiyor, degistirmeniz gerekmez):
MASTER_SHEET_NAME=RANDEVU ALINMIŞLAR
ACCOUNTS_SHEET_NAME=hesap tanımla
# ocr.space/ocrapi/freekey adresinden ucretsiz alinir (ayda 25.000 istek):
OCR_SPACE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
