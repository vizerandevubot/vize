# Bu dosyayi Render'a YUKLEMEYIN. Sadece hangi Environment Variable'lari
# Render dashboard'una (Environment sekmesi) tek tek eklemeniz gerektigini
# gosterir. Degerleri KURULUM.md'deki adimlarla elde edersiniz.

# --- Zorunlu (Telegram + veritabani) ---
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_SECRET=kendi-belirleyeceginiz-tahmin-edilemez-bir-metin
MONGO_URI=mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- E-posta ile hatirlatici bildirimi (opsiyonel, EmailJS) ---
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxx
USER_EMAIL=sevinckudret1@gmail.com

# --- Google Takvim (opsiyonel) ---
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

# --- Gelen kutusu izleme: Gmail, Yandex, Yahoo, iCloud, Zoho, GMX, Mail.ru ---
# ve IMAP destekleyen HERHANGI baska bir saglayici (Outlook/Hotmail HARIC -
# o OAuth ister, asagida ayri bolumde). Sunucu adresi, e-posta adresinin
# @'dan sonraki kismina bakilarak OTOMATIK bulunur - siz sadece adres ve
# uygulama sifresini giriyorsunuz. Her hesap icin numarayi bir artirarak
# devam edin (IMAP_ADDRESS_1, IMAP_ADDRESS_2, ... 20'ye kadar).
IMAP_ADDRESS_1=hesap1@gmail.com
IMAP_APP_PASSWORD_1=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_2=hesap2@gmail.com
IMAP_APP_PASSWORD_2=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_3=hesap3@yandex.com
IMAP_APP_PASSWORD_3=xxxxxxxxxxxxxxxx

IMAP_ADDRESS_4=hesap4@yahoo.com
IMAP_APP_PASSWORD_4=xxxxxxxxxxxxxxxx

# Bilinmeyen/ozel bir domain (sirket maili gibi) kullanan bir hesabiniz
# varsa, sunucu adresini elle belirtmeniz gerekir:
# IMAP_HOST_5=mail.ozelsirketiniz.com
# IMAP_ADDRESS_5=isim@ozelsirketiniz.com
# IMAP_APP_PASSWORD_5=xxxxxxxxxxxxxxxx

# Bildirimde gorunecek ismi degistirmek isterseniz (opsiyonel):
# IMAP_LABEL_1=Fransa Vize Gmail

# Eklerin (resim/pdf/word) Telegram'a gonderilecek azami boyutu (MB):
MAIL_ATTACHMENT_MAX_MB=20

# --- Gelen kutusu izleme: Outlook/Hotmail (OAuth - app password ARTIK CALISMIYOR) ---
# Ayni CLIENT_ID'yi tum hesaplar icin kullanin, her hesap icin AYRI bir
# REFRESH_TOKEN gerekir (get_outlook_refresh_token.py'i her hesap icin bir
# kez, o hesapla giris yaparak calistirin).
OUTLOOK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_REFRESH_TOKEN_1=M.C1xx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OUTLOOK_REFRESH_TOKEN_2=M.C1xx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mail bildirim ayarlari (opsiyonel) ---
# Bos birakilirsa TUM gelen mailler Telegram'a dusurulur. Doldurulursa
# (virgulle ayrilmis) sadece bu kelimelerden birini iceren mailler dusurulur.
EMAIL_KEYWORDS=vize,visa,consulate,embassy,randevu,appointment,sefaret,konsolosluk
MAIL_CHECK_INTERVAL_SECONDS=120

# --- SMS (opsiyonel, kalici ucretsiz servis yok - bos birakilirsa SMS gonderilmez) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
